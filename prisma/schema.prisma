generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth (NextAuth.js v5) ──────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  purchases    Purchase[]
  subscription Subscription?
  couponUses   CouponUse[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

// ── Templates ──────────────────────────────────────────────────
model Template {
  id             String   @id
  title          String
  slug           String   @unique
  description    String
  category       String
  format         String
  fileKey        String   // Supabase Storage private key
  previewImageUrl String
  downloads      Int      @default(0)
  tags           String[]
  isPremium      Boolean  @default(false)
  price          Int?     // KRW (null = 무료)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  purchases Purchase[]
}

// ── Purchase (건별 결제) ───────────────────────────────────────
model Purchase {
  id         String         @id @default(cuid())
  userId     String
  templateId String
  amount     Int            // KRW
  pgTxId     String         @unique // PortOne 거래 ID
  couponId   String?
  status     PurchaseStatus @default(PENDING)
  receiptUrl String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  template Template @relation(fields: [templateId], references: [id])
  coupon   Coupon?  @relation(fields: [couponId], references: [id])
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

// ── Subscription (정기 구독) ───────────────────────────────────
model Subscription {
  id            String             @id @default(cuid())
  userId        String             @unique
  plan          SubscriptionPlan
  status        SubscriptionStatus @default(ACTIVE)
  billingKey    String             // PortOne 빌링키 (암호화 저장)
  customerKey   String             // PortOne 고객 키
  nextBillingAt DateTime
  canceledAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user     User                  @relation(fields: [userId], references: [id])
  payments SubscriptionPayment[]
}

enum SubscriptionPlan {
  MONTHLY  // 9,900원/월
  YEARLY   // 79,000원/년
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model SubscriptionPayment {
  id             String         @id @default(cuid())
  subscriptionId String
  amount         Int
  pgTxId         String         @unique
  status         PurchaseStatus
  failReason     String?
  createdAt      DateTime       @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
}

// ── Coupon ────────────────────────────────────────────────────
model Coupon {
  id        String     @id @default(cuid())
  code      String     @unique
  type      CouponType
  value     Int        // percent(%) 또는 고정금액(KRW)
  maxUses   Int?       // null = 무제한
  usedCount Int        @default(0)
  expiresAt DateTime?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  uses      CouponUse[]
  purchases Purchase[]
}

enum CouponType {
  PERCENT
  FIXED
}

model CouponUse {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([couponId, userId])
}
